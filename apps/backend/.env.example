# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=altrupets_dev_database

# Redis (optional, falls back to in-memory cache)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=24h
MOBILE_PASSWORD_SALT=your-password-salt-here

# Storage
STORAGE_TYPE=local

# Firebase Push Notifications (optional, push disabled if not set)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Throttling
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="AltruPets <noreply@altrupets.app>"

# Application
APP_URL=http://localhost:3000

# Token TTLs (seconds)
EMAIL_VERIFICATION_TTL=86400
PASSWORD_RESET_TTL=3600

# Sentry (optional)
SENTRY_DSN=

# Environment
NODE_ENV=development
ENV_NAME=dev
