---
/**
 * S-11: FinalCTA.astro
 * Final call to action section.
 * Background: primary-20 (#00344E), text white.
 */
import CTAButton from "@/components/ui/CTAButton.astro";
---

<section id="agendar-demo" class="py-16 md:py-24 bg-primary-20">
  <div class="container">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="font-header font-bold text-white text-2xl md:text-3xl lg:text-4xl leading-tight mb-6">
        Su cant&oacute;n merece m&aacute;s que una imagen est&aacute;tica y un n&uacute;mero de tel&eacute;fono.
      </h2>
      <p class="font-primary text-white/80 text-lg md:text-xl leading-relaxed mb-10">
        Agendemos 30 minutos. Si no ve valor en la demo, no le pedimos nada m&aacute;s.
      </p>
      <CTAButton
        text="Agendar demo en vivo"
        href="#agendar-demo"
        variant="primary"
        size="lg"
      />
      <p class="font-tertiary text-sm text-neutral-70 mt-5">
        Sin costo. Sin compromiso. 30 minutos.
      </p>
    </div>
  </div>
</section>
