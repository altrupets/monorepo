---
/**
 * S-02: Hero.astro
 * THE WHAT — Miedo: hero section with two columns.
 * Background: primary-10 (#001E2F), text white.
 */
import CTAButton from "@/components/ui/CTAButton.astro";
---

<section id="hero" class="bg-primary-10 pt-28 md:pt-32 pb-16 md:pb-24">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <!-- Left column: copy -->
      <div class="order-2 md:order-1">
        <h1 class="font-header font-bold text-white text-2xl md:text-3xl lg:text-4xl leading-tight mb-6">
          Deje de ser la operadora telef&oacute;nica de denuncias que no le corresponden.
        </h1>
        <p class="font-primary text-white/90 text-lg md:text-xl leading-relaxed mb-8">
          El 80% de los reportes que recibe su oficina de bienestar animal
          deber&iacute;an ir al OIJ o la Fiscal&iacute;a, no a usted. AltruPets
          filtra y redirige autom&aacute;ticamente, para que usted solo vea los
          casos donde su municipio S&Iacute; puede actuar.
        </p>

        <div id="hero-cta" class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-6">
          <CTAButton
            text="Agendar demo en vivo"
            href="#agendar-demo"
            variant="primary"
            size="lg"
          />
          <CTAButton
            text="Ver video explicativo (3 min)"
            href="#video"
            variant="ghost"
            size="md"
            scrollTo="video"
          />
        </div>

        <p class="font-tertiary text-sm text-neutral-70">
          Ya en proceso con municipios costarricenses
        </p>
      </div>

      <!-- Right column: comparison screenshot placeholder -->
      <div class="order-1 md:order-2">
        <div
          class="bg-primary-20 border-2 border-dashed border-primary-40 rounded-2xl aspect-[4/3] flex items-center justify-center"
        >
          <div class="text-center p-6">
            <svg
              class="mx-auto mb-4 w-16 h-16 text-primary-50 opacity-60"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            <p class="font-primary text-primary-60 text-base font-medium">
              Screenshot comparativo
            </p>
            <p class="font-tertiary text-primary-50 text-sm mt-1">
              P&aacute;gina municipal actual vs Dashboard AltruPets
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
