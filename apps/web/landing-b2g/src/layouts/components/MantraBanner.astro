---
export interface Props {
  text: string;
  bgColor: string;
  textColor: string;
}

const { text, bgColor, textColor } = Astro.props;
---

<section class:list={["py-12 md:py-16 w-full", bgColor]}>
  <div class="container">
    <p
      class:list={[
        "font-primary font-semibold text-xl md:text-2xl leading-relaxed text-center max-w-4xl mx-auto",
        textColor,
      ]}
    >
      {text}
    </p>
  </div>
</section>
