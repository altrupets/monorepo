---
/**
 * S-01: UrgencyBar.astro
 * Persistent urgency bar at the top of the page.
 * Background: error-30 (#842500), text white, fixed/sticky on scroll.
 */
---

<div
  id="urgency-bar"
  class="fixed top-0 left-0 right-0 z-50 bg-error-30 text-white py-2.5 px-4"
>
  <div class="container">
    <p class="text-sm md:text-base font-primary leading-snug text-center">
      <strong class="font-semibold">Ley 7451 de Bienestar Animal</strong> &mdash; Los
      municipios tienen la obligaci&oacute;n de garantizar proteger a los animales
      dom&eacute;sticos en su jurisdicci&oacute;n. Legalmente SENASA no est&aacute;
      obligada a hacerlo.{" "}
      <a
        href="#hero-cta"
        class="font-semibold underline underline-offset-2 hover:text-secondary-90 transition-colors duration-200"
        data-urgency-link
      >
        Ent&eacute;rese c&oacute;mo su municipalidad puede lograrlo.
      </a>
    </p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const links = document.querySelectorAll("[data-urgency-link]");
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.getElementById("hero-cta");
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  });
</script>
