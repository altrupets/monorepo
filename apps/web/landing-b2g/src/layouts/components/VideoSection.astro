---
/**
 * S-09: VideoSection.astro
 * Video embed placeholder with CTAs.
 * Background: primary-10 (#001E2F), text white.
 */
import SectionTitle from "@/components/ui/SectionTitle.astro";
import CTAButton from "@/components/ui/CTAButton.astro";
---

<section id="video" class="py-16 md:py-24 bg-primary-10">
  <div class="container">
    <SectionTitle
      title="Vea el panel en acci\u00F3n (3 minutos)"
      light
    />

    {/* Video placeholder */}
    <div class="max-w-3xl mx-auto mb-10">
      <div class="relative bg-primary-20 border-2 border-dashed border-primary-40 rounded-2xl aspect-video flex items-center justify-center cursor-pointer group hover:border-secondary-60 transition-colors duration-300">
        {/* Play button */}
        <div class="flex flex-col items-center">
          <div class="w-20 h-20 rounded-full bg-secondary/90 flex items-center justify-center shadow-lg group-hover:bg-secondary group-hover:scale-110 transition-all duration-300">
            <svg
              class="w-8 h-8 text-white ml-1"
              fill="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <p class="font-primary text-primary-60 text-sm mt-4">
            Video demo del panel — pr&oacute;ximamente
          </p>
        </div>
      </div>
    </div>

    {/* CTAs */}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <CTAButton
        text="Agendar demo en vivo"
        href="#agendar-demo"
        variant="primary"
        size="lg"
      />
      <CTAButton
        text="Solicitar propuesta formal"
        href="#agendar-demo"
        variant="secondary"
        size="lg"
      />
    </div>
  </div>
</section>
