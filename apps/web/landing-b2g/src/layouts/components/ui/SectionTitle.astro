---
export interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  light?: boolean;
}

const { title, subtitle, align = "center", light = false } = Astro.props;

const alignClass = align === "center" ? "text-center" : "text-left";
const titleColor = light ? "text-white" : "text-neutral-10";
const subtitleColor = light ? "text-neutral-70" : "text-neutral-40";
---

<div class:list={[alignClass, "mb-8"]}>
  <h2
    class:list={[
      "font-header font-bold leading-tight",
      titleColor,
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={[
          "mt-4 font-primary text-lg leading-relaxed",
          subtitleColor,
        ]}
      >
        {subtitle}
      </p>
    )
  }
</div>
