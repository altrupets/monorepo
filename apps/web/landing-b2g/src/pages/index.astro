---
/**
 * Landing page principal: gobierno.altrupets.app
 * Uses Landing layout (minimal header + urgency bar).
 * Sections: UrgencyBar (in layout), Hero, then remaining template sections.
 */
import Landing from "@/layouts/Landing.astro";
import Hero from "@/components/Hero.astro";
import MantraBanner from "@/components/MantraBanner.astro";
---

<Landing
  title="AltruPets — Gesti&oacute;n de Bienestar Animal para Municipios"
  meta_title="AltruPets — Gesti&oacute;n de Bienestar Animal para Municipios"
  description="Cumpla con la Ley 7451 sin depender de SENASA. Panel de control de bienestar animal para su cant&oacute;n."
>
  <!-- S-02: Hero -->
  <Hero />

  <!-- S-03: Mantra 1 (placeholder for ALT-57) -->
  <MantraBanner
    text="Si no puede medir cu&aacute;ntos animales rescat&oacute; su cant&oacute;n este mes, no puede justificar el presupuesto del pr&oacute;ximo."
    bgColor="bg-secondary-90"
    textColor="text-primary"
  />

  <!-- S-04 through S-12: Remaining sections will be implemented in ALT-57 and ALT-58 -->
  <!-- Placeholder sections to demonstrate page flow -->

  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-neutral-10 mb-4">
          Esto es lo que pasa hoy en su municipio
        </h2>
        <p class="font-primary text-neutral-40 text-lg">
          Secci&oacute;n de problemas y soluciones &mdash; pr&oacute;ximamente en ALT-57.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-primary-95">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-neutral-10 mb-4">
          AltruPets es para su municipio si...
        </h2>
        <p class="font-primary text-neutral-40 text-lg">
          Secci&oacute;n de p&uacute;blico objetivo &mdash; pr&oacute;ximamente en ALT-57.
        </p>
      </div>
    </div>
  </section>

  <MantraBanner
    text="Los datos no mienten. Pero para tener datos, primero necesita un sistema."
    bgColor="bg-primary-20"
    textColor="text-white"
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-neutral-10 mb-4">
          Funcionando en su municipio en 3 pasos
        </h2>
        <p class="font-primary text-neutral-40 text-lg">
          Secci&oacute;n de proceso &mdash; pr&oacute;ximamente en ALT-57.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-neutral-95">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-neutral-10 mb-4">
          Municipios que ya est&aacute;n en proceso
        </h2>
        <p class="font-primary text-neutral-40 text-lg">
          Secci&oacute;n de prueba social &mdash; pr&oacute;ximamente en ALT-58.
        </p>
      </div>
    </div>
  </section>

  <section id="video" class="py-16 md:py-24 bg-primary-10">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-white mb-4">
          Vea el panel en acci&oacute;n (3 minutos)
        </h2>
        <p class="font-primary text-neutral-70 text-lg">
          Secci&oacute;n de video &mdash; pr&oacute;ximamente en ALT-58.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-neutral-10 mb-4">
          Preguntas frecuentes
        </h2>
        <p class="font-primary text-neutral-40 text-lg">
          Secci&oacute;n de FAQ &mdash; pr&oacute;ximamente en ALT-58.
        </p>
      </div>
    </div>
  </section>

  <section id="agendar-demo" class="py-16 md:py-24 bg-primary-20">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-header font-bold text-white text-2xl md:text-3xl lg:text-4xl mb-6">
          Su cant&oacute;n merece m&aacute;s que una imagen est&aacute;tica y un n&uacute;mero de tel&eacute;fono.
        </h2>
        <p class="font-primary text-white/80 text-lg md:text-xl mb-8">
          Agendemos 30 minutos. Si no ve valor en la demo, no le pedimos nada m&aacute;s.
        </p>
        <a
          href="#agendar-demo"
          class="inline-block bg-secondary text-white font-primary font-semibold text-lg px-10 py-5 rounded-full hover:brightness-110 hover:shadow-lg transition-all duration-300"
        >
          Agendar demo en vivo
        </a>
        <p class="font-tertiary text-sm text-neutral-70 mt-4">
          Sin costo. Sin compromiso. 30 minutos.
        </p>
      </div>
    </div>
  </section>
</Landing>
